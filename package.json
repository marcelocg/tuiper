{
  "name": "tuiper",
  "version": "0.1.0",
  "description": "Terminal (TUI) typing trainer — a faithful clone of frank_type by Fabio Akita, with byte-identical metrics.",
  "module": "index.ts",
  "type": "module",
  "license": "MIT",
  "author": "Marcelo Gonçalves",
  "homepage": "https://github.com/marcelocg/tuiper",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcelocg/tuiper.git"
  },
  "keywords": ["typing", "tui", "terminal", "opentui", "bun", "wpm"],
  "bin": {
    "tuiper": "index.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "files": ["index.ts", "src", "LICENSE", "README.md"],
  "scripts": {
    "start": "bun run index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build:corpus": "bun run scripts/build-corpus.ts",
    "build:linux": "bun build --compile --target=bun-linux-x64 index.ts --outfile dist/tuiper-linux-x64",
    "build:mac": "bun build --compile --target=bun-darwin-arm64 index.ts --outfile dist/tuiper-darwin-arm64",
    "build:win": "bun build --compile --target=bun-windows-x64 index.ts --outfile dist/tuiper-windows-x64.exe",
    "build:all": "bun run build:linux && bun run build:mac && bun run build:win"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.4.2"
  }
}
